---
import "../styles/global.css";
import ScrollProgress from "../components/ScrollProgress";
---

<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Fabian Lopez | Desarrollador Full-Stack</title>
	</head>
	<body
		class="bg-bg-primary text-text-primary antialiased selection:bg-zinc-800 selection:text-text-primary relative transition-colors duration-300"
	>
		<script is:inline>
			const theme = localStorage.getItem('theme') || 'dark';
			const accent = localStorage.getItem('accent') || '#34d399';
			document.documentElement.setAttribute('data-theme', theme);
			document.documentElement.style.setProperty('--accent', accent);
			
			// Calculate muted accent
			const r = parseInt(accent.slice(1, 3), 16);
			const g = parseInt(accent.slice(3, 5), 16);
			const b = parseInt(accent.slice(5, 7), 16);
			document.documentElement.style.setProperty('--accent-muted', `rgba(${r}, ${g}, ${b}, 0.1)`);
		</script>
		<div class="relative z-10">
			<ScrollProgress client:load />
			<slot />
		</div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
